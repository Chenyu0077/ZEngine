    <graph id="sg2" name="n2" xy="0,0" size="22,22" type="ellipse" lineSize="0" fillColor="#ff5a3a20" touchable="false">
      <gearDisplay controller="button" pages="1,3"/>
      <relation target="" sidePair="width,height"/>
    </graph>
  </displayList>
</component>
